# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Rust Backend API
NEXT_PUBLIC_API_URL=http://localhost:8095
NEXT_PUBLIC_APP_URL=http://localhost:3035

# Encryption (must match backend)
ENCRYPTION_KEY=your-32-byte-base64-key

# Google Calendar OAuth
GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=http://localhost:3035/api/auth/google/callback

# Zoom OAuth
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret
ZOOM_REDIRECT_URI=http://localhost:3035/api/auth/zoom/callback
